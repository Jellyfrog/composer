{
    "name": "composer/separate-plugins",
    "description": "Manage packages in a separate composer file without modifying the default composer.json/lock",
    "type": "composer-plugin",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "composer-plugin-api": "^2.6"
    },
    "autoload": {
        "psr-4": {
            "Composer\\SeparatePlugins\\": "src/"
        }
    },
    "extra": {
        "class": "Composer\\SeparatePlugins\\Plugin"
    }
}
